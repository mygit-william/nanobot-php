{
    "name": "yourname/php-nanobot",
    "type": "project",
    "require": {
        "ext-curl": "*",
        "guzzlehttp/guzzle": "^7.10",
        "symfony/yaml": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
